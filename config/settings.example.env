# Trading Bot Configuration
# Copy this file to .env and fill in your API keys

# CoinGecko API (free demo key optional)
COINGECKO_API_KEY=

# Crypto.com API
CRYPTO_COM_API_KEY=your_api_key_here
CRYPTO_COM_SECRET_KEY=your_secret_key_here

# Forex API (OANDA)
OANDA_API_KEY=your_oanda_api_key_here
OANDA_ACCOUNT_ID=your_oanda_account_id_here
OANDA_ENVIRONMENT=practice  # or 'live'

# Forex API (FXCM) - Alternative
FXCM_API_KEY=your_fxcm_api_key_here
FXCM_ACCOUNT_ID=your_fxcm_account_id_here

# Indian Markets (Zerodha Kite)
ZERODHA_API_KEY=your_zerodha_api_key_here
ZERODHA_API_SECRET=your_zerodha_secret_here
ZERODHA_ACCESS_TOKEN=your_access_token_here

# News APIs
NEWS_API_KEY=your_newsapi_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Local LLM sentiment (LiteLLM + Ollama)
SENTIMENT_ANALYZER=rule_based   # rule_based, local_llm, auto
LOCAL_LLM_ENABLED=false
LOCAL_LLM_BASE_URL=http://localhost:8000
LOCAL_LLM_ENDPOINT=/v1/chat/completions
LOCAL_LLM_MODEL=qwen-coder-3b
LOCAL_LLM_API_KEY=
LOCAL_LLM_TIMEOUT_SECONDS=20
LOCAL_LLM_TEMPERATURE=0.1

# Data providers
MARKET_DATA_PROVIDER=coingecko      # coingecko or crypto_com
FOREX_DATA_PROVIDER=alpha_vantage   # alpha_vantage
NEWS_DATA_PROVIDER=newsapi          # newsapi

# Execution
EXECUTION_MODE=paper                # paper or real
REAL_BROKER_PROVIDER=oanda          # planned: oanda, fxcm, zerodha, crypto_com

# Database
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading_bot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_db_password_here

# Telegram Notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Trading Parameters
MAX_POSITION_SIZE=10000  # Maximum position size in USD
RISK_PER_TRADE=0.02      # Risk 2% per trade
STOP_LOSS_PERCENT=0.05   # 5% stop loss

# System
LOG_LEVEL=INFO
ENVIRONMENT=development  # development, staging, production
